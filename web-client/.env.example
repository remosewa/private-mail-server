# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets.

# Your deployed API Gateway URL
VITE_API_URL=https://api.yourdomain.com

# Cognito User Pool — from CDK outputs or AWS Console
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# VAPID public key — from CDK outputs or `web-push generate-vapid-keys`
VITE_VAPID_PUBLIC_KEY=

# The mail domain users receive email at (e.g. mail.yourdomain.com)
VITE_MAIL_DOMAIN=mail.yourdomain.com
